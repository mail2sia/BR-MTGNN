{
  "base_args": {
    "device": "cuda:1",
    "train": true,
    "trainer_mode": true,
    "has_header": true,
    "residual_head": true,
    "temporal_attn": true,
    "temporal_transformer": 1,
    "tt_layers": 3,
    "attn_heads": 4,
    "attn_dim": 128,
    "attn_dropout": 0.0,
    "data": "./data/sm_data_g.csv",
    "graph": "./data/graph_square.csv",
    "num_nodes": 95,
    "seq_in_len": 120,
    "seq_out_len": 36,
    "epochs": 200,
    "early_stop_patience": 80,
    "mc_runs": 100,
    "train_ratio": 0.7,
    "valid_ratio": 0.2,
    "normalize": 3,
    "dual_channel": "pct",
    "pct_clip": 3.0,
    "y_transform": "log1p",

    "loss_alpha": 5.0,
    "loss_beta": 0.0,
    "loss_gamma": 0.0,
    "mae_weight": 8.0,
    "movement_loss_weight": 5.0,
    "nonzero_weight": 40.0,
    "horizon_gamma": 1.0,
    "huber_delta": 0.5,
    "rmd_loss_weight": 20.0,

    "graph_mix": 0.6,
    "dropedge_p": 0.0,
    "weight_decay": 0.0,

    "no_plots": false,
    "enable_test_plots": true,
    "plot_mode": "all",
    "plot_top_k": 95,

    "smooth_plot": false,
    "plot_trend_smooth": false,
    "smooth_actual_alpha": 0.0,
    "smooth_actual_passes": 1,
    "nan_debug": true
  },
  "grid": {
    "lr": [0.0005, 0.0008],
    "batch_size": [16, 32],
    "layers": [5],
    "gcn_depth": [2],
    "conv_channels": [96],
    "residual_channels": [96],
    "skip_channels": [192],
    "end_channels": [384],
    "dropout": [0.0],
    "clip": [5.0, 8.0],
    "node_dim": [80],
    "subgraph_size": [40],
    "propalpha": [0.05],
    "tanhalpha": [3]
  },
  "targets": {
    "rse": 0.40,
    "rae": 0.40
  },
  "score": {
    "w_rse": 0.6,
    "w_rae": 0.35,
    "w_ci": 0.05
  },
  "run_tag_prefix": "ultra_hugging",
  "runs_dir": "runs",
  "force_fresh_start": true,
  "max_trials": 8,
  "top_n": 6,
  "timeout": 0
}
